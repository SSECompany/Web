// Tasks - phân kỳ theo tháng: WorkflowTasks_yyyymm
Table WorkflowTasks_yyyymm {
  Id             bigint [pk, increment]
  DepId          int [not null]
  CompanyCode    nvarchar(16) [not null]
  ProjectId      int
  ParentTaskId   bigint
  TaskCode       nvarchar(50) [not null]
  TaskName       nvarchar(255) [not null]
  Level          int [default: 1]
  Status         nvarchar(30) [default: 'PENDING']
  Priority       nvarchar(20) [default: 'MEDIUM']
  Mode           nvarchar(20) [default: 'INTERNAL']
  Category       nvarchar(50)
  FormTemplate   nvarchar(50)
  EstimatedHours decimal(10,2)
  ActualHours    decimal(10,2) [default: 0]
  Progress       decimal(5,2) [default: 0]
  StartDate      datetime
  EndDate        datetime
  DueDate        datetime
  CompletedDate  datetime
  AssignedBy     int
  AssignedTo     int
  ReviewerId     int
  Description    nvarchar(max)
  CreatedBy      int [not null]
  IsDeleted      bit [default: 0]
  RecordStatus   tinyint [default: 1]
  datetime0      datetime2
  datetime2      datetime2
  user_id0       int
  user_id2       int
}

