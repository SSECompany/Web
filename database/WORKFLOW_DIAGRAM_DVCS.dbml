

Table WorkflowCompanies {
  Id           int [pk, increment]
  CompanyCode  nvarchar(16) [not null, unique]
  Name         nvarchar(255) [not null]
  Domain       nvarchar(255)
  IsActive     bit [default: 1]
  CreatedBy    nvarchar(255)
  IsDeleted    bit [default: 0]
  RecordStatus tinyint [default: 1]
  datetime0    datetime2
  datetime2    datetime2
  user_id0     int
  user_id2     int
}

Table WorkflowOrgUnits {
  Id           int [pk, increment]
  DepId        int [not null]
  CompanyCode  nvarchar(16) [not null]
  ParentId     int
  UnitCode     nvarchar(50) [not null]
  UnitName     nvarchar(255) [not null]
  Level        int [default: 1]
  IsActive     bit [default: 1]
  CreatedBy    nvarchar(255)
  IsDeleted    bit [default: 0]
  RecordStatus tinyint [default: 1]
  datetime0    datetime2
  datetime2    datetime2
  user_id0     int
  user_id2     int
}

Table WorkflowUsers {
  Id           int [pk, increment]
  DepId        int [not null]
  CompanyCode  nvarchar(16) [not null]
  EmployeeCode nvarchar(50) [not null]
  FullName     nvarchar(255) [not null]
  Email        nvarchar(255) [not null]
  Phone        nvarchar(20)
  OrgUnitId    int [not null]
  Level        int [default: 1]
  Title        nvarchar(255)
  Status       nvarchar(20) [default: 'ACTIVE']
  AvatarUrl    nvarchar(500)
  IsAdmin      bit [default: 0]
  IsSup        bit [default: 0]
  IsDeleted    bit [default: 0]
  RecordStatus tinyint [default: 1]
  datetime0    datetime2
  datetime2    datetime2
  user_id0     int
  user_id2     int
}

Table WorkflowUserRoles {
  Id           int [pk, increment]
  DepId        int [not null]
  CompanyCode  nvarchar(16) [not null]
  UserId       int [not null]
  RoleCode     nvarchar(50) [not null]
  ScopeType    nvarchar(20) [default: 'ORG']
  ScopeId      int
  GrantedDate  datetime [default: 'GETDATE()']
  IsDeleted    bit [default: 0]
  RecordStatus tinyint [default: 1]
  datetime0    datetime2
  datetime2    datetime2
  user_id0     int
  user_id2     int
}

Table WorkflowProjects {
  Id               int [pk, increment]
  DepId            int [not null]
  CompanyCode      nvarchar(16) [not null]
  Level            int [default: 1]
  ProjectCode      nvarchar(50) [not null]
  ProjectName      nvarchar(255) [not null]
  Status           nvarchar(30) [default: 'PLANNING']
  Priority         nvarchar(20) [default: 'MEDIUM']
  ProjectManagerId int [not null]
  OrgUnitId        int [not null]
  ClientName       nvarchar(255)
  HealthStatus     nvarchar(20) [default: 'GOOD']
  Progress         decimal(5,2) [default: 0]
  StartDate        datetime [not null]
  EndDate          datetime [not null]
  Budget           decimal(18,2)
  BudgetUsed       decimal(18,2) [default: 0]
  Description      nvarchar(max)
  CreatedBy        int [not null]
  UpdatedBy        int
  IsDeleted        bit [default: 0]
  RecordStatus     tinyint [default: 1]
  datetime0        datetime2
  datetime2        datetime2
  user_id0         int
  user_id2         int
}

Table WorkflowProjectMembers {
  Id           int [pk, increment]
